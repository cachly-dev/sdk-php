{
  "name": "cachly-dev/sdk",
  "description": "Official PHP SDK for cachly.dev – Managed Valkey/Redis cache with semantic AI caching",
  "type": "library",
  "license": "MIT",
  "version": "0.1.0-beta.1",
  "keywords": ["redis", "valkey", "cache", "cachly", "semantic-cache", "llm", "dsgvo", "eu"],
  "homepage": "https://cachly.dev",
  "authors": [
    {
      "name": "cachly.dev",
      "email": "hello@cachly.dev",
      "homepage": "https://cachly.dev"
    }
  ],
  "require": {
    "php": "^8.1",
    "predis/predis": "^2.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "Cachly\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Cachly\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "beta",
  "prefer-stable": true
}

